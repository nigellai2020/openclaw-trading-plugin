{
  "id": "trading-plugin",
  "skills": ["./skills"],
  "contracts": {
    "tools": [
      "get_token_prices",
      "get_ohlc",
      "get_supported_pairs",
      "get_agent_trades",
      "get_open_positions",
      "get_nostr_identity",
      "get_hyperliquid_balance",
      "get_evm_wallet_balance",
      "get_billing_subscriptions",
      "get_agent",
      "update_agent",
      "init_trading_session",
      "setup_live_wallet",
      "prepare_agent_creation",
      "deploy_agent",
      "search_public_agents",
      "list_my_agents",
      "delete_agent",
      "list_wallets",
      "delete_wallet",
      "create_backtest",
      "get_backtests",
      "get_backtest_job",
      "get_backtest_result",
      "backtest_leader_board"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "https://agent02.decom.dev"
      },
      "nostrPrivateKey": {
        "type": "string"
      },
      "walletAgentUrl": {
        "type": "string",
        "default": "https://wallet-agent.decom.dev"
      },
      "settlementEngineUrl": {
        "type": "string",
        "default": "https://settlement-agent.decom.dev"
      },
      "enableAmmSpot": {
        "type": "boolean",
        "default": false
      },
      "billingEnvironment": {
        "type": "string",
        "enum": ["test", "prod"],
        "default": "test"
      },
      "bscBillingRpcUrl": {
        "type": "string",
        "default": "https://data-seed-prebsc-1-s1.binance.org:8545"
      },
      "bscBillingRouterAddress": {
        "type": "string",
        "default": "0x8AEb7abBCfe0ED8baAfa3ddD2CdE39cDBb4d0106"
      },
      "bscBillingWethAddress": {
        "type": "string",
        "default": "0xae13d989dac2f0debff460ac112a837c89baa7cd"
      },
      "bscBillingTokenAddress": {
        "type": "string",
        "default": "0x45eee762aaeA4e5ce317471BDa8782724972Ee19"
      },
      "bscBillingTokenSymbol": {
        "type": "string",
        "default": "OSWAP"
      },
      "bscBillingTokenDecimals": {
        "type": "number",
        "default": 18
      },
      "bscBillingVaultAddress": {
        "type": "string",
        "default": "0x15780a63c8a47dd27c4c7f7d17673929e0cb4d05"
      },
      "bscEligibleNftAddress": {
        "type": "string",
        "default": "0xc32c70c6cc2338daa3fdfbb25c98f1227c673175"
      },
      "bscEligibleNftExplorerUrl": {
        "type": "string",
        "default": "https://testnet.bscscan.com/address/0xc32c70c6cc2338daa3fdfbb25c98f1227c673175"
      },
      "bscEligibleNftName": {
        "type": "string",
        "default": "Troll NFT"
      },
      "bscEligibleNftMinimumStake": {
        "type": "number",
        "default": 20
      },
      "bscEligibleNftProtocolFee": {
        "type": "number",
        "default": 10
      },
      "bscEligibleNftTotalMintingFee": {
        "type": "number",
        "default": 30
      },
      "billingSwapSlippageBps": {
        "type": "number",
        "default": 50
      },
      "billingPollIntervalMs": {
        "type": "number",
        "default": 5000
      },
      "billingPollTimeoutMs": {
        "type": "number",
        "default": 90000
      },
      "nostrRelayUrl": {
        "type": "string",
        "default": "wss://nos.lol"
      }
    }
  }
}
