{
  "id": "trading-plugin",
  "skills": ["./skills"],
  "contracts": {
    "tools": [
      "get_token_prices",
      "get_ohlc",
      "get_supported_pairs",
      "get_agent_trades",
      "get_open_positions",
      "close_all_trades",
      "get_nostr_identity",
      "get_hyperliquid_balance",
      "get_evm_wallet_balance",
      "get_agent",
      "update_agent",
      "init_trading_session",
      "request_hyperliquid_setup_flow",
      "deploy_agent",
      "search_public_agents",
      "list_my_agents",
      "delete_agent",
      "list_wallets",
      "update_wallet",
      "delete_wallet",
      "create_backtest",
      "get_backtests",
      "get_backtest_job",
      "get_backtest_result",
      "backtest_leader_board"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "https://agent02.decom.dev"
      },
      "webUrl": {
        "type": "string",
        "default": "https://agent.openswap.xyz"
      },
      "nostrPrivateKey": {
        "type": "string"
      },
      "walletAgentUrl": {
        "type": "string",
        "default": "https://wallet-agent.decom.dev"
      },
      "settlementEngineUrl": {
        "type": "string",
        "default": "https://settlement-agent.decom.dev"
      },
      "hyperliquidManagementUrl": {
        "type": "string",
        "default": "https://hyperliquid.openswap.xyz"
      },
      "enableAmmSpot": {
        "type": "boolean",
        "default": false
      },
      "defaultHyperliquidNetwork": {
        "type": "string",
        "enum": ["testnet", "mainnet"],
        "default": "testnet"
      },
      "nostrRelayUrl": {
        "type": "string",
        "default": "wss://nos.lol"
      }
    }
  }
}
